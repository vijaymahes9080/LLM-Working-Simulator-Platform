dist/
build/
*.egg-info/
*.egg
.eggs/
wheels/
*.whl
MANIFEST
pip-wheel-metadata/

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
nosetests.xml
test-results/

