# -----------------------------------------------------------------------------
node_modules/
.pnp/
.pnp.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.yarn/install-state.gz

# Next.js build output
.next/
out/

# Production build
dist/
build/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Storybook
.storybook/storybook-static/

